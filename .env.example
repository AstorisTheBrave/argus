# Argus configuration by environment variable.
#
# Every value here has a safe default; copy to `.env` and uncomment only what
# you need. Precedence is constructor kwargs > environment > defaults, so
# anything set in code (e.g. Argus(bot, port=...)) wins over these. Booleans
# accept 1/0, true/false, yes/no, on/off.
#
# Two surfaces live in this file:
#   1. The per-bot SDK (ARGUS_*)         - read by Argus(bot) inside your bot.
#   2. The Fleet control plane (ARGUS_FLEET_* server vars) - read by
#      `python -m argus.fleet`, a separate process. It is fully optional.

# ----------------------------------------------------------------------------
# 1. Per-bot SDK (the Argus(bot) one-liner)
# ----------------------------------------------------------------------------

# Where the metrics/dashboard server binds.
#ARGUS_HOST=0.0.0.0
#ARGUS_PORT=9191

# The Prometheus scrape path.
#ARGUS_METRICS_PATH=/metrics

# Stable id for this process; becomes the bounded `cluster` Prometheus label.
# Give each process in a clustered/sharded deploy a distinct value.
#ARGUS_CLUSTER_ID=default

# Metric name prefix (e.g. discord_guilds). Keep stable across a fleet.
#ARGUS_NAMESPACE=discord

# Built-in live dashboard (served at ARGUS_DASHBOARD_PATH).
#ARGUS_DASHBOARD=true
#ARGUS_DASHBOARD_PATH=/
#ARGUS_DASHBOARD_INTERVAL=5
# When set, the dashboard and all /api/* routes require this bearer token.
#ARGUS_DASHBOARD_AUTH_TOKEN=

# Optional: link out to your Grafana from the dashboard.
#ARGUS_GRAFANA_URL=

# Optional: push spans/metrics to an OpenTelemetry collector (needs the
# `argus-dpy[otlp]` extra).
#ARGUS_OTLP_ENDPOINT=

# Optional per-guild analytics (the analytical path, separate from Prometheus).
# Needs the `argus-dpy[clickhouse]` extra; the analytics API fails closed
# without ARGUS_DASHBOARD_AUTH_TOKEN.
#ARGUS_ENABLE_PER_GUILD=false
#ARGUS_CLICKHOUSE_DSN=

# ----------------------------------------------------------------------------
# 1b. Per-bot: opt into a Fleet control plane (member side)
# ----------------------------------------------------------------------------
# Unset = no fleet code runs (behaviour is exactly as without these). Set
# ARGUS_FLEET_URL to make the bot register + heartbeat to a control plane.

#ARGUS_FLEET_URL=http://fleet-host:9190
#ARGUS_FLEET_TOKEN=change-me
# The region/tier this process belongs to (the Fleet tier in the UI).
#ARGUS_FLEET_GROUP=default
# A stable identity; if unset, a UUID is generated and persisted to
# ARGUS_FLEET_STATE_DIR so a restart keeps the same fleet number.
#ARGUS_FLEET_ID=
#ARGUS_FLEET_STATE_DIR=.
# Optional: advertise this bot's reachable metrics address so the control plane's
# /api/fleet/targets (Prometheus http_sd) can auto-discover it for scraping.
#ARGUS_FLEET_SCRAPE_TARGET=10.0.0.5:9191

# ----------------------------------------------------------------------------
# 2. Fleet control plane server (python -m argus.fleet)
# ----------------------------------------------------------------------------

#ARGUS_FLEET_HOST=0.0.0.0
#ARGUS_FLEET_PORT=9190
# Shared secret; gates every route except /healthz and /readyz. Members send the
# same token. A non-loopback bind with no token REFUSES to start (secure default).
#ARGUS_FLEET_TOKEN=change-me
# Or read the token from a mounted secret file instead of the env var.
#ARGUS_FLEET_TOKEN_FILE=/run/secrets/argus_fleet_token
# Optional split-token model: a low-privilege INGEST token (put this on every bot
# as ARGUS_FLEET_TOKEN) and a VIEWER token (operators, for the UI/APIs). Each
# falls back to ARGUS_FLEET_TOKEN above if unset. (*_FILE variants also exist.)
#ARGUS_FLEET_INGEST_TOKEN=
#ARGUS_FLEET_VIEWER_TOKEN=
# Allow a public bind without a token (LOCAL TESTING ONLY; do not use in prod).
#ARGUS_FLEET_INSECURE=0
# Max request body in bytes (snapshots are a few KiB); oversized -> 413.
#ARGUS_FLEET_MAX_BODY_BYTES=262144
# Opt-in CORS allowlist (comma-separated). Only needed if you serve the UI from a
# DIFFERENT origin than the API; leave empty for the bundled same-origin UI.
#ARGUS_FLEET_CORS_ORIGINS=https://dashboard.example.com
# Short cache so many viewers share one view computation / Prometheus query batch.
#ARGUS_FLEET_VIEW_CACHE_MS=1000
# Liveness: a cluster is "up" while last_seen is within interval * ttl_factor.
#ARGUS_FLEET_HEARTBEAT_INTERVAL=15
#ARGUS_FLEET_TTL_FACTOR=3
# Abuse caps (generous defaults). Bursts are token-bucket capacities per 60s.
#ARGUS_FLEET_MAX_CLUSTERS=5000
#ARGUS_FLEET_REGISTER_BURST=60
#ARGUS_FLEET_HEARTBEAT_BURST=60
# Prune clusters down longer than this many days (0 = never, the default).
#ARGUS_FLEET_RETENTION_DAYS=0
# Where the registry (per-fleet numbers + topology) persists across restarts.
#ARGUS_FLEET_STATE=argus-fleet-state.json
# Optional: read metric values from an existing Prometheus (joined with push).
#ARGUS_FLEET_PROMETHEUS_URL=http://prometheus:9090
# Metric prefix; must match the members' ARGUS_NAMESPACE.
#ARGUS_NAMESPACE=discord
